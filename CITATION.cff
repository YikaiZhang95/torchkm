repository-code: "https://github.com/YikaiZhang95/torchkm"
url: "https://yikaizhang95.github.io/torchkm/"
license: MIT
version: 4.2.3
# date-released is in YYYY-MM-DD; update on each tagged release:
date-released: "2026-05-23"
keywords:
  - machine-learning
  - kernel-methods
  - support-vector-machine
  - distance-weighted-discrimination
  - kernel-logistic-regression
  - quantile-regression
  - nystrom-approximation
  - pytorch
  - gpu
  - scikit-learn

